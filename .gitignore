Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json

# IDEs and Editors (VS Code, Visual Studio, CLion, etc.)
.vscode/
.vs/
.idea/
*.user

# OS specific
.DS_Store
Thumbs.db
